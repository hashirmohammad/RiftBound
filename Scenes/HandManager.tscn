[sub_resource type="GDScript" id="GDScript_r0y0a"]
script/source = "class_name HandManager
extends HBoxContainer
## HandManager — Unified hand system. Replaces PlayerHand.gd entirely.
##
## Inherits HBoxContainer so Godot handles horizontal layout automatically.
## Tween animations (deal slide-in, failed-drag return) merged from PlayerHand.
##
## Scene placement:
##   Add HandManager as a child of Board's \"Hand\" panel.
##   Set anchors to fill the panel (Left=0, Top=0, Right=1, Bottom=1).
##   Inspector → Alignment: Center  |  Separation: 8
##
## Wired by:
##   Deck.gd         → deal_card(data)
##   CardManager.gd  → remove_card(card)  /  return_card(card)

const CARD_SCENE   := preload(\"res://Scenes/Card.tscn\")
const DEAL_SPEED   := 0.35
const RETURN_SPEED := 0.15
const NORMAL_SCALE := Vector2(0.8, 0.8)

var cards_in_hand: Array[RiftCard] = []

# ── Public API ────────────────────────────────────────────────────────────────

## Instantiates a new RiftCard from CardData and adds it to the hand.
## Returns the card so Deck can play the flip animation on it.
func deal_card(data: CardData) -> RiftCard:
	var card: RiftCard = CARD_SCENE.instantiate()
	card.load_from_resource(data)
	card.scale    = NORMAL_SCALE
	card.modulate = Color(1, 1, 1, 0)          # fade in during deal anim
	cards_in_hand.append(card)
	add_child(card)
	_tween_deal(card)
	return card

## Removes a successfully played card from the hand.
## The card node is NOT freed — CardManager reparents it to the board slot.
func remove_card(card: RiftCard) -> void:
	if cards_in_hand.has(card):
		cards_in_hand.erase(card)
		remove_child(card)

## Returns a failed-drag card back into the hand with a smooth tween.
func return_card(card: RiftCard) -> void:
	if not cards_in_hand.has(card):
		cards_in_hand.append(card)
		add_child(card)
	card.set_card_state(RiftCard.CardState.IN_HAND)
	card.z_index = 1
	_tween_return(card)

func has_card(card: RiftCard) -> bool:
	return cards_in_hand.has(card)

# ── Animations ────────────────────────────────────────────────────────────────

func _tween_deal(card: RiftCard) -> void:
	var tween = create_tween().set_parallel(true)
	tween.tween_property(card, \"modulate\", Color.WHITE, DEAL_SPEED)
	tween.tween_property(card, \"scale\",    NORMAL_SCALE, DEAL_SPEED) \\
		.from(NORMAL_SCALE * 0.7)

func _tween_return(card: RiftCard) -> void:
	var tween = create_tween()
	tween.set_ease(Tween.EASE_OUT).set_trans(Tween.TRANS_BACK)
	tween.tween_property(card, \"scale\", NORMAL_SCALE, RETURN_SPEED)
"

